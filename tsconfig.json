{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./.homeybuild",
    "declaration": false
  },
  "include": ["app.ts", "lib/**/*.ts", "drivers/**/*.ts"],
  "exclude": ["node_modules", ".homeybuild"]
}
